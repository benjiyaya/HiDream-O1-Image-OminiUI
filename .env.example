# ── Ollama (local LLM with tool calling) ──
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=

# ── OpenAI-compatible API (prompt enhancement, optional) ──
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# ── HiDream-O1-Image ──
HIDREAM_API_URL=http://localhost:7860
HIDREAM_MODEL_PATH=
HIDREAM_MODEL_TYPE=dev

# Auto-save directory for generated images
HIDREAM_RESULTS_DIR=../HiDream-O1-Image/results

# Auto-unload HiDream model after this many ms of inactivity (default 10 min)
MODEL_IDLE_TIMEOUT_MS=600000

# ── Server ──
PORT=3001
